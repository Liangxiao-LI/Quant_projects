AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: route Bedrock Runtime through a VPC interface endpoint or HTTPS proxy.
# Leave blank to use the default public Bedrock endpoint for the region.
AWS_BEDROCK_RUNTIME_ENDPOINT_URL=

# Reasoning model for entity extraction + relationship LLM.
# Examples:
#   - Anthropic: anthropic.claude-3-5-sonnet-20240620-v1:0
#   - DeepSeek (catalog id from console): deepseek.v3.2
#   - Cross-Region inference profile (if AWS requires it for your model): e.g. us.deepseek.r1-v1:0
BEDROCK_REASONING_MODEL_ID=deepseek.v3.2

BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# Must match the embedding model output dimension (e.g. 1024 for Titan v2 default)
BEDROCK_EMBEDDING_DIMENSION=1024

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket_agents

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Optional Neo4j (Version 2+); leave empty to disable
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

LOG_LEVEL=INFO
